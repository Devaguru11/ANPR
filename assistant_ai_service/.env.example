# Service
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=9001
AI_SERVICE_API_KEY=change-me-internal-key

# vLLM
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
VLLM_MODEL_PATH=./models/Qwen2.5-7B-Instruct-AWQ
VLLM_TIMEOUT=45

# Database (read-only analytics_ai user)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=analytics_ai
DB_PASSWORD=
DB_NAME=aiserver

# Redis
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_MEMORY_TTL=86400
REDIS_MAX_TURNS=20

# Limits
SQL_MAX_ROWS=10000
SQL_TIMEOUT_SECONDS=30
ENTITY_CACHE_REFRESH_SECONDS=300
